# Supabase — copy this file to `.env` and fill in your project's values.
# Find them in the Supabase dashboard → Project Settings → API.
# The anon key is safe to expose in the browser (protected by Row-Level Security).
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Google Analytics 4 — optional. Set to your Measurement ID (e.g. G-XXXXXXX) to
# enable analytics. Loads only after the visitor accepts analytics cookies.
VITE_GA_MEASUREMENT_ID=
